# =============================================================================
# .dockerignore — Excluded from Docker build context
# Keeps images lean and prevents sensitive files from leaking into layers.
# =============================================================================

# Version control
.git/
.gitignore

# Python build artifacts
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/
.tox/
.venv/
venv/
env/
.env

# Test / coverage artifacts
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.coveragerc

# Type checking
.mypy_cache/

# IDE / editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Generated outputs (bind-mounted at runtime instead)
results/
figures/out/
checkpoints/
logs/
data/

# Large model files
*.pt
*.pth
*.ckpt
*.safetensors
*.h5
*.hdf5

# Jupyter checkpoints
.ipynb_checkpoints/

# Documentation build
docs/_build/
docs/out/
site/

# Singularity image files
*.sif
*.simg

# Container files (not needed inside container)
containers/

# CI/CD
.github/

# Temporary files
tmp/
temp/
*.tmp
*.log
*.pid
