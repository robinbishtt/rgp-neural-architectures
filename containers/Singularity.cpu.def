# =============================================================================
# RGP Neural Architectures — CPU-Only Singularity Definition
# Renormalization-Group Principles for Deep Neural Network Depth
#
# PURPOSE:
#   CPU-only variant for HPC clusters where GPU resources are limited
#   or for lightweight testing/verification tasks.
#
# USE CASES:
#   - Pipeline verification (make verify_pipeline)
#   - Unit and integration testing
#   - Small-scale prototyping
#   - CPU partitions of HPC clusters
#   - CI/CD pipelines
#
# BUILD:
#   singularity build --fakeroot rgp-neural-cpu.sif containers/Singularity.cpu.def
#
# USAGE:
#   singularity run rgp-neural-cpu.sif make verify_pipeline
#   singularity run rgp-neural-cpu.sif make test_unit
#
# NOTE:
#   This container does NOT include CUDA support.
#   For GPU experiments, use the main Singularity.def instead.
# =============================================================================

Bootstrap: docker
From: ubuntu:22.04

%labels
    Maintainer Anonymous Author
    Version 1.1.0-cpu
    Project RGP Neural Architectures (CPU-only)
    Description CPU-only container for RGP experiments
    Python 3.9.18
    PyTorch 2.0.1+cpu
    License MIT

%help
    RGP Neural Architectures — CPU-Only Container

    This is the CPU-only variant for lightweight tasks:
    • Pipeline verification
    • Unit testing
    • Small-scale experiments

    QUICK START:
        singularity run rgp-neural-cpu.sif make verify_pipeline
        singularity run rgp-neural-cpu.sif make test_unit

    NOTE: No GPU support. Use rgp-neural.sif for GPU experiments.

%environment
    export DEBIAN_FRONTEND=noninteractive
    export TZ=UTC
    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8
    export PYTHONDONTWRITEBYTECODE=1
    export PYTHONUNBUFFERED=1
    export PYTHONHASHSEED=0
    export PYTHONPATH=/workspace:$PYTHONPATH
    export PATH=/opt/conda/bin:$PATH
    export RGP_WORKSPACE=/workspace
    export RGP_SEED=${RGP_SEED:-42}

%post
    echo "=== Building RGP CPU-Only Container ==="

    # System dependencies
    export DEBIAN_FRONTEND=noninteractive
    apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        git \
        wget \
        curl \
        ca-certificates \
        libhdf5-dev \
        libffi-dev \
        libssl-dev \
        libblas-dev \
        liblapack-dev \
        libopenblas-dev \
        gfortran \
        pkg-config \
        cmake \
        make \
        rsync \
        unzip \
        vim \
        time \
        && rm -rf /var/lib/apt/lists/*

    # Miniconda with Python 3.9.18
    wget -q https://repo.anaconda.com/miniconda/Miniconda3-py39_23.11.0-2-Linux-x86_64.sh \
        -O /tmp/miniconda.sh
    bash /tmp/miniconda.sh -b -p /opt/conda
    rm /tmp/miniconda.sh
    export PATH=/opt/conda/bin:$PATH
    conda install -y python=3.9.18
    conda clean -afy

    # PyTorch CPU-only
    pip install --no-cache-dir \
        torch==2.0.1+cpu \
        torchvision==0.15.2+cpu \
        --index-url https://download.pytorch.org/whl/cpu

    # Core dependencies
    pip install --no-cache-dir \
        numpy==1.24.3 \
        scipy==1.11.1 \
        sympy==1.12 \
        matplotlib==3.7.2 \
        pandas==2.0.3 \
        h5py==3.9.0 \
        pyyaml==6.0.1 \
        hydra-core==1.3.2 \
        omegaconf==2.3.0 \
        tqdm==4.65.0 \
        tensorboard==2.13.0 \
        pytest==7.4.3 \
        pytest-cov==4.1.0 \
        black==23.7.0 \
        isort==5.12.0 \
        mypy==1.4.1 \
        scikit-learn==1.3.0

    # Create workspace
    mkdir -p /workspace/{src,tests,experiments,results,figures,logs}
    chmod -R 755 /workspace

    echo "=== CPU-Only Build Complete ==="

%runscript
    #!/bin/bash
    cd /workspace
    if [ $# -eq 0 ]; then
        echo "RGP Neural Architectures — CPU-Only Container"
        echo "Usage: singularity run rgp-neural-cpu.sif <command>"
        echo ""
        echo "Recommended commands:"
        echo "  make verify_pipeline    # Quick verification"
        echo "  make test_unit          # Unit tests"
        echo "  make test_integration   # Integration tests"
        exec make verify_pipeline
    else
        exec "$@"
    fi

%test
    #!/bin/bash
    echo "RGP CPU-Only Container Test"
    python --version
    python -c "import torch; print(f'PyTorch: {torch.__version__}'); print(f'CUDA: {torch.cuda.is_available()}')"
    python -c "import numpy, scipy, sympy, matplotlib; print('Core deps: OK')"
    echo "CPU container ready!"
